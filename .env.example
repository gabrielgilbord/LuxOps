# Copia a .env.local y rellena valores reales. No subas .env / .env.local al repositorio.

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Producto / precio de suscripción mensual (Price ID)
STRIPE_PRICE_ID_MONTHLY=
# Secreto del endpoint de webhook (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=

# URL pública de la app (checkout, enlaces)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Opcional: origen canónico solo para sitemap.xml y robots.txt (debe coincidir con Google Search Console)
# NEXT_PUBLIC_CANONICAL_URL=https://luxops.es

# Identidad legal (RGPD / LSSI — textos legales y pie de dossier PDF)
NEXT_PUBLIC_LEGAL_NAME=[TU_NOMBRE_COMPLETO]
NEXT_PUBLIC_LEGAL_DNI=[TU_DNI]
NEXT_PUBLIC_LEGAL_ADDRESS=[TU_DIRECCIÓN_POSTAL]
NEXT_PUBLIC_LEGAL_EMAIL=[TU_EMAIL_DE_SOPORTE]

# Resend (https://resend.com) — bienvenida tras pago, operario, certificados
RESEND_API_KEY=re_...
# Remitente verificado en Resend (dominio o onboarding@resend.dev en pruebas)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Supabase, DATABASE_URL, etc. — ver documentación del proyecto
